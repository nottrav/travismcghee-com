---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .filter(project => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const connectLinks = [
  ...SOCIALS.map((social) => ({
    href: social.HREF,
    label: social.NAME,
    external: true,
  })),
  ...(SITE.EMAIL
    ? [{
        href: `mailto:${SITE.EMAIL}`,
        label: SITE.EMAIL,
        external: false,
      }]
    : []),
];

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-1 mb-8">
      <h1 class="animate text-hero font-semibold tracking-tight text-black dark:text-white">
        Travis McGhee
      </h1>
      <p class="animate font-mono text-sm text-black/50 dark:text-white/50">
        Cybersecurity · Privacy · IT
      </p>
    </div>
    <div class="space-y-16">
      <section>
        <article class="space-y-4 max-w-2xl border-l-2 border-black/10 dark:border-white/10 pl-4">
          <p class="animate">
            I'm a recent Rutgers grad with a degree in Information Technology, a concentration in Cybersecurity, and a minor in Digital Communication. I write here about cybersecurity and privacy, mostly real risks, common scam patterns, and practical ways to build safer habits online.
          </p>
          <p class="animate">
            The investigative side of security is what got me hooked. I like digging into how systems work and figuring out where they break down. My background covers networking, security, data analytics, and privacy, and I've applied that through projects in Python, Java, and tools like Tableau. At home I run a Raspberry Pi with Pi-hole to experiment with DNS filtering and keep an eye on what's actually moving across my network.
          </p>
          <p class="animate">
            I'm currently looking for entry-level roles in cybersecurity or IT. If my work looks like a good fit for what your team is building, I'd love to hear from you.
          </p>
        </article>
        <div class="animate mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-mono text-black/50 dark:text-white/50">
          <span class="flex items-center gap-1.5">
            <span class="text-[var(--accent)]">&gt;</span> Security & Privacy
          </span>
          <span class="flex items-center gap-1.5">
            <span class="text-[var(--accent)]">&gt;</span> DNS & Networking
          </span>
          <span class="flex items-center gap-1.5">
            <span class="text-[var(--accent)]">&gt;</span> Data Analytics
          </span>
          <span class="flex items-center gap-1.5">
            <span class="text-[var(--accent)]">&gt;</span> Digital Communication
          </span>
        </div>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h2 class="text-xl font-semibold text-black dark:text-white">
            Featured projects
          </h2>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} showTags={false} featured={true} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h2 class="text-xl font-semibold text-black dark:text-white">
            Latest posts
          </h2>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h2 class="text-xl font-semibold text-black dark:text-white">
          Let's Connect
        </h2>
        <article>
          <p>
            If you want to connect, collaborate, or discuss cybersecurity, reach out
            on social media.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {connectLinks.map((item, index) => (
            <li class="flex gap-x-2 text-nowrap">
              <Link
                href={item.href}
                external={item.external}
                aria-label={item.external ? `${SITE.NAME} on ${item.label}` : `Email ${SITE.NAME}`}
              >
                {item.label}
              </Link>
              {index < connectLinks.length - 1 && "/"}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>

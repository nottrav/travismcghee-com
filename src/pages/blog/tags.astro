---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { tagToSlug } from "@lib/utils";

const posts = (await getCollection("blog")).filter((post) => !post.data.draft);

const tagCounts = new Map<string, { label: string; count: number }>();
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    const slug = tagToSlug(tag);
    const existing = tagCounts.get(slug);
    if (existing) {
      existing.count++;
    } else {
      tagCounts.set(slug, { label: tag, count: 1 });
    }
  });
});

const tags = Array.from(tagCounts.entries())
  .map(([slug, { label, count }]) => ({ slug, label, count }))
  .sort((a, b) => b.count - a.count);

const totalPosts = posts.length;
---

<PageLayout title="Tags" description="Browse all blog post topics">
  <Container>
    <div class="space-y-10">
      <div class="animate">
        <div class="flex items-center justify-between gap-2">
          <h1 class="font-semibold text-black dark:text-white">Tags</h1>
          <Link href="/blog">Back to blog</Link>
        </div>
        <p class="font-mono text-sm text-black/50 dark:text-white/50 mt-2">
          {tags.length} topics across {totalPosts} posts
        </p>
      </div>

      <div class="animate grid grid-cols-1 sm:grid-cols-2 gap-3">
        {tags.map((tag) => (
          <a
            href={`/blog/tag/${tag.slug}`}
            class="tag-card group relative rounded-lg border border-black/15 dark:border-white/20 px-4 py-4 no-underline transition-all duration-300 ease-in-out hover:border-[var(--accent-muted)] hover:bg-[var(--accent-subtle)] hover:-translate-y-0.5 hover:shadow-sm overflow-hidden"
          >
            <div class="scan-line absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            <div class="flex flex-col gap-1.5">
              <span class="font-semibold text-black dark:text-white text-sm group-hover:tracking-wide transition-all duration-300">
                {tag.label}
              </span>
              <span class="font-mono text-xs text-black/50 dark:text-white/50">
                {tag.count} {tag.count === 1 ? "post" : "posts"}
              </span>
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="tag-arrow absolute top-1/2 right-3 -translate-y-1/2 size-4 stroke-2 fill-none stroke-current opacity-0 group-hover:opacity-100 transition-all duration-300"
            >
              <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
              <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>

<style>
  .scan-line::after {
    content: "";
    position: absolute;
    top: -100%;
    left: 0;
    right: 0;
    height: 200%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.02) 2px,
      rgba(0, 0, 0, 0.02) 4px
    );
    animation: scan 4s linear infinite;
    pointer-events: none;
  }

  :global(.dark) .scan-line::after {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255, 255, 255, 0.02) 2px,
      rgba(255, 255, 255, 0.02) 4px
    );
  }

  @keyframes scan {
    0% { transform: translateY(0); }
    100% { transform: translateY(50%); }
  }

  .tag-card:hover .tag-arrow {
    stroke: var(--accent);
  }
</style>

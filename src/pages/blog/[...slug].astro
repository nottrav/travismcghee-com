---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { getDisplayTags, readingTime, tagToSlug } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import TableOfContents from "@components/TableOfContents.astro";
import SeriesNav from "@components/SeriesNav.astro";

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft);

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await post.render();
const tags = getDisplayTags(post.data.tags, 2);

const seriesPosts = post.data.series
  ? allPosts.filter((p) => p.data.series?.name === post.data.series!.name)
  : [];
---

<PageLayout title={post.data.title} description={post.data.description} ogType="article">
  <Container>
    <div class="animate">
      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5 text-sm font-mono text-black/50 dark:text-white/50">
        <FormattedDate date={post.data.date} />
        <span>&bull;</span>
        <span>{readingTime(post.body)}</span>
      </div>
      <h1 class="animate text-3xl font-semibold tracking-tight text-black dark:text-white">
        {post.data.title}
      </h1>
      {(tags.length > 0 || post.data.series) && (
        <div class="animate flex flex-wrap items-center gap-2 pt-2">
          {post.data.series && (
            <span class="font-mono text-xs rounded-md px-2 py-1 border border-black/15 dark:border-white/20">
              {post.data.series.name} · Part {post.data.series.order}
            </span>
          )}
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tagToSlug(tag)}`}
              class="tag-link no-underline font-mono text-xs rounded-md px-2 py-1 border border-black/15 dark:border-white/20 hover:border-[var(--accent-muted)] hover:bg-[var(--accent-subtle)] hover:scale-105 transition-all duration-200"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </div>
    <div class="animate">
      <TableOfContents headings={headings} />
    </div>
    <article class="animate">
      <Content />
    </article>
    {post.data.series && seriesPosts.length > 1 && (
      <div class="animate">
        <SeriesNav currentPost={post} seriesPosts={seriesPosts} />
      </div>
    )}
  </Container>
</PageLayout>

<style>
  .tag-link:hover {
    color: var(--accent);
  }
</style>

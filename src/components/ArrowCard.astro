---
import type { CollectionEntry } from "astro:content";
import { cn, getDisplayTags, tagToSlug } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
  showTags?: boolean;
  featured?: boolean;
}

const { entry, showTags = true, featured = false } = Astro.props;
const tags = showTags && entry.collection === "blog"
  ? getDisplayTags(entry.data.tags, 2)
  : [];

const cardClasses = cn(
  "arrow-card relative group flex flex-nowrap py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-[var(--accent-subtle)] hover:border-[var(--accent-muted)] hover:text-black dark:hover:text-white hover:-translate-y-0.5 hover:shadow-sm transition-all duration-300 ease-in-out",
  featured && "border-l-2 border-l-[var(--accent)]"
);

const cardDivClasses = cn(
  "arrow-card relative group py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-[var(--accent-subtle)] hover:border-[var(--accent-muted)] hover:text-black dark:hover:text-white hover:-translate-y-0.5 hover:shadow-sm transition-all duration-300 ease-in-out",
  featured && "border-l-2 border-l-[var(--accent)]"
);
---

{tags.length === 0 ? (
  <a
    href={`/${entry.collection}/${entry.slug}`}
    class={cardClasses}
  >
    <div class="flex flex-col flex-1 min-w-0">
      <div class="text-lg font-semibold truncate">
        {entry.data.title}
      </div>
      <div class="text-sm leading-snug text-black/60 dark:text-white/60 line-clamp-2 mt-0.5">
        {entry.data.description}
      </div>
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="arrow-icon absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current transition-colors duration-300"
    >
      <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
      <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
    </svg>
  </a>
) : (
  <div
    class={cardDivClasses}
  >
    <a
      href={`/${entry.collection}/${entry.slug}`}
      class="absolute inset-0 z-0"
      aria-label={entry.data.title}
    ></a>
    <div class="flex flex-col flex-1 min-w-0">
      <div class="text-lg font-semibold truncate">
        {entry.data.title}
      </div>
      <div class="text-sm leading-snug text-black/60 dark:text-white/60 line-clamp-2 mt-0.5">
        {entry.data.description}
      </div>
      <div class="relative z-10 flex flex-wrap gap-1.5 mt-2">
        {tags.map((tag) => (
          <a
            href={`/blog/tag/${tagToSlug(tag)}`}
            class="tag-link no-underline font-mono text-xs rounded-md px-2 py-0.5 border border-black/15 dark:border-white/20 hover:border-[var(--accent-muted)] hover:bg-[var(--accent-subtle)] hover:scale-105 transition-all duration-200"
          >
            {tag}
          </a>
        ))}
      </div>
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="arrow-icon absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current transition-colors duration-300"
    >
      <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
      <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
    </svg>
  </div>
)}

<style>
  .arrow-card:hover .arrow-icon {
    stroke: var(--accent);
  }
  .tag-link:hover {
    color: var(--accent);
  }
</style>
